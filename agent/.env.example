# SAP connection
SAP_ASHOST=192.168.1.10
SAP_SYSNR=00
SAP_CLIENT=100
SAP_USER=SAPSCOPE_RFC
SAP_PASSWD=secret
SAP_LANG=EN

# SAPscope backend
SAPSCOPE_BACKEND_URL=https://sapscope.example.com
SAPSCOPE_TOKEN=eyJ...

# Optional tuning
SAPSCOPE_TIMEOUT=30
SAPSCOPE_VERIFY_SSL=true
SAPSCOPE_TADIR_LIMIT=10000
