# ─────────────────────────────────────────────────────────────────
#  SAPscope — Self-Hosted Configuration
#  Copier ce fichier en .env et remplir les valeurs
# ─────────────────────────────────────────────────────────────────

# ── Obligatoire ───────────────────────────────────────────────────

# Mot de passe PostgreSQL (générer avec : openssl rand -hex 32)
POSTGRES_PASSWORD=changeme

# Clé secrète JWT pour les sessions utilisateur (openssl rand -hex 32)
SAPSCOPE_JWT_SECRET=changeme

# URL publique de l'application (utilisée pour les liens dans les emails)
APP_URL=http://votre-serveur

# Port HTTP exposé (défaut : 80)
HTTP_PORT=80

# ── SMTP — Reset de mot de passe (optionnel) ──────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=password
# SMTP_FROM=noreply@votre-domaine.com

# ── Rapport journalier par email (optionnel) ──────────────────────
# REPORT_ENABLED=true
# REPORT_HOUR=7
# REPORT_TZ=Europe/Paris
