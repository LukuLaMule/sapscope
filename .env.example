# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password

# ── Backend ───────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SAPSCOPE_JWT_SECRET=change_me_64_char_random_string_here_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Comma-separated allowed origins for CORS (your frontend URL)
ALLOWED_ORIGINS=https://app.sapscope.io

# "development" enables /docs and SQL echo
ENV=production
DEBUG=false
