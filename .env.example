# ── Base de données ───────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password

# ── Backend ───────────────────────────────────────────────────────────────────
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
SAPSCOPE_JWT_SECRET=change_me_64_char_random_string_here_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clé API Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Origines CORS autorisées (l'URL de ton frontend)
ALLOWED_ORIGINS=https://app.sapscope.com

# "development" active /docs et les logs SQL — ne pas mettre en prod
ENV=production
DEBUG=false

# ── Mode déploiement ──────────────────────────────────────────────────────────
# true  → SaaS, n'importe qui peut s'inscrire
# false → self-hosted, l'admin crée les comptes manuellement
REGISTRATION_ENABLED=false

# ── Self-hosted : licence ─────────────────────────────────────────────────────
# Clé de licence générée par generate_license.py (obligatoire en self-hosted)
# Laisser vide en mode SaaS
LICENSE_KEY=

# ── Stripe (SaaS uniquement) ──────────────────────────────────────────────────
# Laisser vide si tu ne gères pas le billing toi-même
# Dashboard Stripe → Développeurs → Clés API
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs des abonnements (Dashboard Stripe → Produits → Tarifs)
STRIPE_PRICE_SOLO=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_ENTERPRISE=
