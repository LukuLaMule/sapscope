# ── Base de données ───────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_mot_de_passe_fort

# ── JWT (générer avec : openssl rand -hex 32) ─────────────────────────────────
SAPSCOPE_JWT_SECRET=changeme_jwt_secret

# ── Licence SAPscope (reçue par email après inscription) ──────────────────────
LICENSE_KEY=votre-clé-de-licence-uuid

# ── URLs ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://sapscope.yourdomain.com
APP_URL=https://sapscope.yourdomain.com

# ── SMTP (optionnel — pour reset de mot de passe et rapports PDF) ─────────────
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

# ── Rapport PDF journalier (optionnel) ────────────────────────────────────────
REPORT_ENABLED=true
REPORT_HOUR=7
REPORT_TZ=Europe/Paris

# ── Paramètres avancés ────────────────────────────────────────────────────────
ENV=production
DEBUG=false
REGISTRATION_ENABLED=false
